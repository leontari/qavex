#######################################################################
# GITATTRIUTES COMMON SETTINGS
# adopted from examples: https://github.com/gitattributes/gitattributes
#
# Line-ending normalization:
#   text    → Git treats the file as text and normalizes line endings
#             (i.e. CRLF is converted to LF in the repository).
#   binary  → Git leaves the file completely untouched.
#
# Note: "binary" is a shorthand for "-text -diff", meaning:
#       - Git will NOT normalize line endings.
#       - Git will NOT attempt to diff the file.
#######################################################################
#
#######################################
# Global setting
#######################################
# Detect text files and convert them to LF. Do nothing with binary.
*                    text=auto eol=lf
#
#######################################
# Source code
#######################################
*.bash               text eol=lf
*.bat                text eol=crlf
*.c                  text
*.cjs                text
*.cmd                text eol=crlf
*.coffee             text
*.cpp                text
*.csh                text eol=lf
