#
#######################################
# GitHub Linguist overrides
#######################################
# Fix syntax highlighting
tsconfig.json        linguist-language=JSON-with-Comments
# Mark generated files
external-deps/**/*   linguist-generated=true
dist/**/*            linguist-generated=true
*.pyc                linguist-generated=true
*.map                linguist-generated=true
*.min.js             linguist-generated=true
# Mark vendored dependencies
vendor/**            linguist-vendored=true
third_party/**       linguist-vendored=true
# Mark documentation
docs/**              linguist-documentation=true
# Exclude tests from language stats
tests/**             linguist-detectable=false
# Exclude SQL migrations from stats
migrations/**        linguist-detectable=false
# Force binary classification
*.dat                linguist-binary=true
# Disable heuristics for ambiguous extensions
*.inc                linguist-heuristics=false
